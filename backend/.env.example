PORT=4000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=orl-platform-dems
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Initial admin accounts used by POST /api/auth/seed-demo
# JSON array format: [{"email":"...","displayName":"...","phoneNumber":"...","initialPassword":"..."}]
INITIAL_ADMIN_ACCOUNTS=[{"email":"admin@example.com","displayName":"Admin Principal","phoneNumber":"0600000000","initialPassword":"ChangeMe123!"}]

# Optional global fallback Cloudinary credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (Authorization Code flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000
GOOGLE_AUTH_SUCCESS_REDIRECT=http://localhost:3000/oauth/google
GOOGLE_AUTH_FAILURE_REDIRECT=http://localhost:3000/sign-in

# Password reset flow
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# Keep false in production unless you intentionally want the API to return reset links.
PASSWORD_RESET_EXPOSE_LINK=false

# SMTP email sender (used by POST /api/auth/forgot-password)
SMTP_HOST=smtp.example.com # e.g., smtp.gmail.com
SMTP_PORT=587 # Use 465 for secure, 587 for unsecure (with STARTTLS)
SMTP_SECURE=false # true for 465, false for other ports
SMTP_USER= # Your SMTP username (e.g., email address)
SMTP_PASS= # For Gmail, use a Google App Password (16 chars), not your account password
SMTP_FROM_NAME=DEMS ENT # Name shown in sent emails
SMTP_FROM_EMAIL=no-reply@example.com # Email address shown in sent emails (e.g., no-reply@yourdomain.com)
